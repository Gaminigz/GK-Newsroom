{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["es2023"],
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "src/**/*.mjs"]
}
