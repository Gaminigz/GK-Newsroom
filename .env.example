# Copy this file to `.env` and fill in the two secrets. .env is gitignored.

# MongoDB Atlas connection string. GK stack: cluster `Cluster0`
# (cluster0.rnuc0oz.mongodb.net) on the gamini@ggmt.sg Atlas account.
MONGO_URL="mongodb+srv://<user>:<pass>@cluster0.rnuc0oz.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0"

# Database name inside the cluster. Defaults to `yaikh` if unset (legacy);
# the GK Newsroom stack uses `gk_newsroom`.
MONGO_DB="gk_newsroom"

# Google AI Studio key on a Cloud Billing account with the Free Trial credit
# still active (create at https://aistudio.google.com/apikey; pick
# "Default Gemini Project" during creation so the credit is charged).
GEMINI_API_KEY="AQ.Ab8RN6K..."
